# Obsidian - ignore everything first
.obsidian/*
# Then whitelist what should be synced
!.obsidian/plugins/
!.obsidian/plugins/**
!.obsidian/community-plugins.json
!.obsidian/snippets/
!.obsidian/snippets/**
# Blacklist sensitive plugin data
.obsidian/plugins/obsidian-media-db-plugin/data.json
*-Conflict.json
# OS
.DS_Store
Thumbs.db
.trash/
# Sync conflicts
*.sync-conflict-*
